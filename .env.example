# Token del bot obtenido desde @BotFather en Telegram
BOT_TOKEN=123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID numérico del grupo (negativo para supergrupos, ej: -1001234567890)
GRUPO_ID=-1001234567890
# ID numérico del administrador
ADMIN_ID=999999999
# API ID y API HASH obtenidos desde https://my.telegram.org/apps
# Necesarios para el script de inicialización (Telethon userbot)
API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890

# Días de inactividad para avisar al admin (warning) y fecha límite de expulsión (removal)
MAX_DAYS_INACTIVE_WARNING=30
MAX_DAYS_INACTIVE_REMOVAL=60